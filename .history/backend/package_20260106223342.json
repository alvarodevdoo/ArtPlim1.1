{
  "name": "artplim-backend",
  "version": "1.0.0",
  "description": "Backend do ArtPlimERP - Fastify + Prisma",
  "main": "dist/server.js",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:generate": "pnpm exec prisma generate",
    "db:push": "pnpm exec prisma db push",
    "db:migrate": "pnpm exec prisma migrate dev",
    "db:studio": "pnpm exec prisma studio",
    "seed:products": "tsx scripts/seed-products.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "date-fns": "^2.30.0",
    "exceljs": "^4.4.0",
    "fastify": "^4.25.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@prisma/client": "5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/exceljs": "^0.5.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.6",
    "fast-check": "^4.5.3",
    "jest": "^30.2.0",
    "pino-pretty": "^13.1.3",
    "prisma": "5.22.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
