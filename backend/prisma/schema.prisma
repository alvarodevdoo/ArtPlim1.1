model ChartOfAccount {
  id              String            @id @default(uuid())
  organizationId  String
  name            String
  code            String?
  description     String?
  nature          AccountNature
  type            ChartAccountType
  parentId        String?
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent          ChartOfAccount?   @relation("ChartAccountHierarchy", fields: [parentId], references: [id])
  children        ChartOfAccount[]  @relation("ChartAccountHierarchy")
  categories      Category[]
  revenueProducts Product[]         @relation("ProductRevenueAccount")
  systemRole      AccountSystemRole @default(GENERAL)

  // Existing relations
  expenseMaterials    Material[]           @relation("MaterialExpenseAccount")
  inventoryMaterials  Material[]           @relation("MaterialInventoryAccount")
