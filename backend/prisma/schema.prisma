generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                     String                   @id @default(uuid())
  name                   String
  razaoSocial            String?
  cnpj                   String?                  @unique
  slug                   String                   @unique
  plan                   String                   @default("basic")
  active                 Boolean                  @default(true)
  email                  String?
  phone                  String?
  zipCode                String?
  address                String?
  addressNumber          String?
  complement             String?
  neighborhood           String?
  city                   String?
  state                  String?
  logoFull               String?
  logoIcon               String?
  logoScale              Int                      @default(100)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  defaultCommissionRate  Decimal                  @default(0) @db.Decimal(10, 2)
  maxDiscountThreshold   Decimal                  @default(0) @db.Decimal(10, 2)
  materialTypes          MaterialType[]
  spedAccountMappings    SpedAccountMapping[]
  accounts               Account[]
  accountsPayable        AccountPayable[]
  accountsReceivable     AccountReceivable[]
  auditLogs              AuditLog[]
  authorizationRequests  AuthorizationRequest[]
  automationRules        AutomationRule[]
  budgets                Budget[]
  categories             Category[]
  chartOfAccounts        ChartOfAccount[]
  commissionEntries      CommissionEntry[]
  commissionRules        CommissionRule[]
  configurationTemplates ConfigurationTemplate[]
  deliveries             Delivery[]
  fichasTecnicas         FichaTecnicaInsumo[]
  finishes               Finish[]
  inventoryAlerts        InventoryAlert[]
  inventoryMovements     InventoryMovement[]
  machines               Machine[]
  materialReceipts       MaterialReceipt[]
  materials              Material[]
  notifications          Notifications[]
  orderSequence          OrderSequence?
  orders                 Order[]
  settings               OrganizationSettings?
  PaymentMethod          PaymentMethod[]
  pendingChanges         PendingChanges[]
  pricingRules           PricingRule[]
  processStatuses        ProcessStatus[]
  productionMaterials    ProductionMaterial[]
  productionOrders       ProductionOrder[]
  productionQueue        ProductionQueue[]
  products               Product[]
  balanceMovements       ProfileBalanceMovement[]
  profiles               Profile[]
  recurringBills         RecurringBill[]
  roles                  Role[]
  standardSizes          StandardSize[]
  stockMovements         StockMovement[]
  stockReservations      StockReservation[]
  transactions           Transaction[]
  users                  User[]

  @@map("organizations")
}

model OrganizationSettings {
  id                          String       @id @default(uuid())
  organizationId              String       @unique
  enableWMS                   Boolean      @default(false)
  enableProduction            Boolean      @default(false)
  enableFinance               Boolean      @default(true)
  enableAutomation            Boolean      @default(true)
  defaultMarkup               Float        @default(2.0)
  taxRate                     Float        @default(0.0)
  validadeOrcamento           Int          @default(7)
  enableFinanceReports        Boolean      @default(true)
  allowDuplicatePhones        Boolean      @default(true)
  requireDocumentKeyForEntry  Boolean      @default(false)
  enableCategoryAppropriation Boolean      @default(true)
  defaultSalesUnit            String       @default("MM")
  defaultReceivableCategoryId String?
  defaultRevenueCategoryId    String?
  freightExpenseAccountId     String?
  taxExpenseAccountId         String?
  inventoryValuationMethod    String       @default("AVERAGE")

  // Senha Mestre de Backup / Recuperação
  defaultBackupPassword       String?
  recoveryToken               String?

  // Certificado Digital NF-e (A1)
  nfeCertificate              String?
  nfeCertificatePassword      String?
  nfeCertificateSubject       String?
  nfeCertificateFileName      String?
  nfeCertificateExpiry        DateTime?

  // Regras de Pedidos e Faturamento
  requireOrderDeposit         Boolean      @default(false)
  minDepositPercent           Float        @default(0.0)
  allowDeliveryWithBalance    Boolean      @default(true)
  defaultDueDateDays          Int          @default(0)
  enableCommissions           Boolean      @default(true)
  workflowMode                String       @default("FREE")
  requiredCustomerFields      Json         @default("[]")

  // Textos editáveis para impressão de pedidos/orçamentos
  printFooterNotes            String?
  printBudgetNotes            String?

  // Chave PIX para cobrança em links públicos
  pixKey                      String?
  pixKeyType                  String?      // CPF | CNPJ | EMAIL | PHONE | RANDOM
  pixBeneficiary              String?      // Nome do beneficiário

  organization                Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

model User {
  id                 String                 @id @default(uuid())
  organizationId     String
  email              String
  password           String
  name               String
  role               UserRole               @default(USER)
  roleId             String?
  active             Boolean                @default(true)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  auditLogs          AuditLog[]
  approvedAuths      AuthorizationRequest[] @relation("ApprovedAuths")
  requestedAuths     AuthorizationRequest[] @relation("RequestedAuths")
  commissionEntries  CommissionEntry[]
  inventoryMovements InventoryMovement[]
  notifications      Notifications[]
  statusHistory      OrderStatusHistory[]
  artDesignerOrders  Order[]                @relation("OrderArtDesigner")
  cancelledOrders    Order[]                @relation("OrderCancelledBy")
  packagingOrders    Order[]                @relation("OrderPacker")
  productionOrders   Order[]                @relation("OrderProducer")
  soldOrders         Order[]                @relation("OrderSeller")
  requestedChanges   PendingChanges[]       @relation("RequestedBy")
  reviewedChanges    PendingChanges[]       @relation("ReviewedBy")
  profile            Profile?
  cancelledMovements StockMovement[]        @relation("CancelledMovements")
  stockMovements     StockMovement[]        @relation("UserMovements")
  transactions       Transaction[]
  organization       Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customRole         Role?                  @relation(fields: [roleId], references: [id])

  @@unique([organizationId, email])
  @@map("users")
}

model MaterialType {
  id             String               @id @default(uuid())
  name           String
  spedCode       String
  organizationId String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id])
  mappings       SpedAccountMapping[]
  materials      Material[]

  @@index([organizationId])
}

model SpedAccountMapping {
  id             String          @id @default(uuid())
  organizationId String
  materialTypeId String?
  spedType       String
  accountId      String
  mappingType    SpedAccountType @default(EXPENSE)
  createdAt      DateTime        @default(now())
  account        ChartOfAccount  @relation(fields: [accountId], references: [id])
  materialType   MaterialType?   @relation(fields: [materialTypeId], references: [id], onDelete: Cascade)
  organization   Organization    @relation(fields: [organizationId], references: [id])

  @@index([organizationId, materialTypeId])
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  userId         String?
  action         String
  tableName      String
  recordId       String
  oldValues      Json?
  newValues      Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Profile {
  id                     String                   @id @default(uuid())
  organizationId         String
  type                   ProfileType
  name                   String
  document               String?
  email                  String?
  phone                  String?
  address                String?
  city                   String?
  state                  String?
  zipCode                String?
  isCustomer             Boolean                  @default(false)
  isSupplier             Boolean                  @default(false)
  isEmployee             Boolean                  @default(false)
  creditLimit            Decimal?                 @db.Decimal(10, 2)
  paymentTerms           Int?
  paymentMode            SupplierPaymentMode      @default(ON_PURCHASE)
  paymentDayOfMonth      Int?
  defaultPaymentMethodId String?
  active                 Boolean                  @default(true)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  addressNumber          String?
  addressComplement      String?
  neighborhood           String?
  tradeName              String?
  stateRegistration      String?
  municipalRegistration  String?
  savedBillingContacts   Json?
  balance                Decimal                  @default(0) @db.Decimal(15, 2)
  userId                 String?                  @unique
  exemptFromDeposit      Boolean                  @default(false)
  AccountPayable         AccountPayable[]
  AccountReceivable      AccountReceivable[]      @relation("CustomerReceivables")
  budgets                Budget[]
  insumoFornecedores     InsumoFornecedor[]
  MaterialReceipt        MaterialReceipt[]
  materialSuppliers      MaterialSupplier[]
  onDemandMaterials      Material[]               @relation("MaterialPrimarySupplier")
  orders                 Order[]
  balanceMovements       ProfileBalanceMovement[]
  defaultPaymentMethod   PaymentMethod?           @relation("ProfileDefaultPaymentMethod", fields: [defaultPaymentMethodId], references: [id])
  organization           Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                   User?                    @relation(fields: [userId], references: [id])
  stockMovements         StockMovement[]          @relation("SupplierMovements")
  transactions           Transaction[]

  @@unique([organizationId, name], name: "organizationId_name")
  @@unique([organizationId, document], name: "organizationId_document")
  @@map("profiles")
}

model ProfileBalanceMovement {
  id             String       @id @default(uuid())
  organizationId String
  profileId      String
  amount         Decimal      @db.Decimal(15, 2)
  type           String
  description    String
  orderId        String?
  createdAt      DateTime     @default(now())
  order          Order?       @relation(fields: [orderId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  profile        Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("profile_balance_movements")
}

model Material {
  id                           String                @id @default(uuid())
  organizationId               String
  name                         String
  description                  String?
  format                       MaterialFormat
  costPerUnit                  Decimal               @db.Decimal(10, 4)
  unit                         String
  controlUnit                  ControlUnit?
  conversionFactor             Float                 @default(1.0)
  width                        Float?
  height                       Float?
  purchaseWidth                Float?
  purchaseHeight               Float?
  purchaseUnit                 String?
  multiplicador_padrao_entrada Int?                  @default(1)
  active                       Boolean               @default(true)
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt
  categoryId                   String
  defaultConsumptionFactor     Decimal               @default(1.0) @db.Decimal(10, 4)
  defaultConsumptionRule       ConsumptionRule       @default(FIXED_UNIT)
  expenseAccountId             String?
  inventoryAccountId           String?
  minStockQuantity             Float?
  sellWithoutStock             Boolean               @default(true)
  trackStock                   Boolean               @default(true)
  sourcingMode                 SourcingMode          @default(STOCK)
  primarySupplierId            String?
  ncm                          String?
  ean                          String?
  spedType                     String?
  materialTypeId               String?
  averageCost                  Decimal               @default(0) @db.Decimal(10, 4)
  purchasePrice                Decimal?              @db.Decimal(10, 2)
  currentStock                 Decimal               @default(0) @db.Decimal(15, 4)
  optionSlots                  ConfigurationOption[] @relation("OptionMaterial")
  fichasTecnicas               FichaTecnicaInsumo[]
  fornecedores                 InsumoFornecedor[]
  inventoryAlerts              InventoryAlert[]
  inventoryItems               InventoryItem[]
  receiptItems                 MaterialReceiptItem[]
  suppliers                    MaterialSupplier[]
  category                     Category              @relation(fields: [categoryId], references: [id])
  expenseAccount               ChartOfAccount?       @relation("MaterialExpenseAccount", fields: [expenseAccountId], references: [id])
  inventoryAccount             ChartOfAccount?       @relation("MaterialInventoryAccount", fields: [inventoryAccountId], references: [id])
  materialType                 MaterialType?         @relation(fields: [materialTypeId], references: [id])
  organization                 Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  primarySupplier              Profile?              @relation("MaterialPrimarySupplier", fields: [primarySupplierId], references: [id])
  components                   ProductComponent[]
  productionWastes             ProductionWaste[]
  stockMovements               StockMovement[]
  stockReservations            StockReservation[]

  @@unique([organizationId, name], name: "organizationId_name")
  @@index([organizationId])
  @@index([organizationId, categoryId])
  @@index([organizationId, active])
  @@map("materials")
}

model InventoryItem {
  id         String              @id @default(uuid())
  materialId String
  width      Float
  length     Float?
  height     Float?
  thickness  Float?
  quantity   Int                 @default(1)
  location   String?
  isOffcut   Boolean             @default(false)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  material   Material            @relation(fields: [materialId], references: [id], onDelete: Cascade)
  movements  InventoryMovement[]

  @@map("inventory_items")
}

model Product {
  id                     String                 @id @default(uuid())
  organizationId         String
  name                   String
  description            String?
  productType            ItemType               @default(PRODUCT)
  pricingMode            PricingMode            @default(SIMPLE_AREA)
  salePrice              Decimal?               @db.Decimal(10, 2)
  minPrice               Decimal?               @db.Decimal(10, 2)
  costPrice              Decimal?               @db.Decimal(10, 2)
  markup                 Float                  @default(2.0)
  active                 Boolean                @default(true)
  priceLocked            Boolean                @default(false)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  pricingRuleId          String?
  stockMinQuantity       Float?
  stockQuantity          Float?
  stockUnit              String?
  trackStock             Boolean                @default(false)
  formulaData            Json?
  localFormulaId         String?
  customFormula          String?
  sellWithoutStock       Boolean                @default(true)
  targetMarkup           Float?
  targetMargin           Float?
  categoryId             String?
  revenueAccountId       String?
  isCommissionable       Boolean                @default(true)
  specificCommissionRate Decimal?               @db.Decimal(10, 2)
  maxDiscountThreshold   Decimal?               @db.Decimal(10, 2)
  operations             ProductOperation[]
  budgetItems            BudgetItem[]
  fichasTecnicas         FichaTecnicaInsumo[]
  orderItems             OrderItem[]
  components             ProductComponent[]
  configurations         ProductConfiguration[]
  standardSizes          ProductStandardSize[]
  productionWastes       ProductionWaste[]
  category               Category?              @relation(fields: [categoryId], references: [id])
  organization           Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pricingRule            PricingRule?           @relation(fields: [pricingRuleId], references: [id])
  revenueAccount         ChartOfAccount?        @relation("ProductRevenueAccount", fields: [revenueAccountId], references: [id])
  stockReservations      StockReservation[]

  @@unique([organizationId, name], name: "organizationId_name")
  @@map("products")
}

model StockReservation {
  id             String       @id @default(uuid())
  organizationId String
  orderId        String
  productId      String?
  materialId     String?
  quantity       Decimal      @db.Decimal(15, 4)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  material       Material?    @relation(fields: [materialId], references: [id], onDelete: Cascade)
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product        Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, organizationId])
  @@index([materialId, organizationId])
  @@index([orderId])
  @@map("stock_reservations")
}

model ProductConfiguration {
  id                String                   @id @default(uuid())
  productId         String
  name              String
  description       String?
  helpText          String?
  type              ConfigurationType
  kind              ConfigurationKind        @default(VARIATION)
  required          Boolean                  @default(true)
  defaultValue      String?
  affectsComponents Boolean                  @default(false)
  affectsPricing    Boolean                  @default(false)
  minValue          Float?
  maxValue          Float?
  step              Float?
  displayOrder      Int                      @default(1)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  options           ConfigurationOption[]
  orderItemConfigs  OrderItemConfiguration[]
  product           Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_configurations")
}

model ConfigurationOption {
  id                   String                   @id @default(uuid())
  configurationId      String
  label                String
  value                String
  description          String?
  priceModifier        Decimal                  @default(0) @db.Decimal(10, 2)
  priceModifierType    String                   @default("FIXED")
  priceOverride        Decimal?                 @db.Decimal(10, 2)
  fixedValue           Decimal?                 @db.Decimal(10, 2)
  additionalComponents Json?
  removedComponents    Json?
  componentModifiers   Json?
  isAvailable          Boolean                  @default(true)
  displayOrder         Int                      @default(1)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  materialId           String?
  slotQuantity         Decimal?                 @db.Decimal(10, 4)
  defaultQuantity      Decimal?                 @db.Decimal(10, 4)
  minQuantity          Decimal?                 @db.Decimal(10, 4)
  maxQuantity          Decimal?                 @db.Decimal(10, 4)
  allowCustomQty       Boolean                  @default(false)
  allowedChildIds      Json?
  configuration        ProductConfiguration     @relation(fields: [configurationId], references: [id], onDelete: Cascade)
  material             Material?                @relation("OptionMaterial", fields: [materialId], references: [id])
  fichasTecnicas       FichaTecnicaInsumo[]
  incompatibilitiesA   OptionIncompatibility[]  @relation("IncompatA")
  incompatibilitiesB   OptionIncompatibility[]  @relation("IncompatB")
  orderItemConfigs     OrderItemConfiguration[]

  @@map("configuration_options")
}

model OptionIncompatibility {
  id        String              @id @default(uuid())
  optionAId String
  optionBId String
  reason    String?
  createdAt DateTime            @default(now())
  optionA   ConfigurationOption @relation("IncompatA", fields: [optionAId], references: [id], onDelete: Cascade)
  optionB   ConfigurationOption @relation("IncompatB", fields: [optionBId], references: [id], onDelete: Cascade)

  @@unique([optionAId, optionBId])
  @@map("option_incompatibilities")
}

model ConfigurationTemplate {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  description    String?
  category       String       @default("custom")
  configurations Json
  metadata       Json
  usageCount     Int          @default(0)
  createdBy      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("configuration_templates")
}

model OrderItemConfiguration {
  id               String               @id @default(uuid())
  orderItemId      String
  configurationId  String
  selectedValue    String
  selectedOptionId String?
  customQuantity   Decimal?             @db.Decimal(10, 4)
  createdAt        DateTime             @default(now())
  configuration    ProductConfiguration @relation(fields: [configurationId], references: [id])
  orderItem        OrderItem            @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  selectedOption   ConfigurationOption? @relation(fields: [selectedOptionId], references: [id])

  @@map("order_item_configurations")
}

model ProductionWaste {
  id              String            @id @default(uuid())
  orderId         String
  productId       String
  materialId      String
  componentId     String?
  plannedQuantity Float
  actualQuantity  Float
  wasteQuantity   Float
  wasteReason     String
  reportedBy      String
  reportedAt      DateTime          @default(now())
  component       ProductComponent? @relation(fields: [componentId], references: [id])
  material        Material          @relation(fields: [materialId], references: [id])
  order           Order             @relation(fields: [orderId], references: [id])
  product         Product           @relation(fields: [productId], references: [id])

  @@map("production_wastes")
}

model ProductStandardSize {
  id        String  @id @default(uuid())
  productId String
  name      String
  width     Float
  height    Float
  isDefault Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_standard_sizes")
}

model ProductComponent {
  id                        String            @id @default(uuid())
  productId                 String
  materialId                String
  consumptionMethod         String
  wastePercentage           Float             @default(0.0)
  calculatedWastePercentage Float             @default(0.0)
  manualWastePercentage     Float?
  wasteUnits                Float             @default(0.0)
  manualWasteUnits          Float?
  lastWasteUpdate           DateTime          @default(now())
  wasteCalculationPeriod    Int               @default(90)
  isOptional                Boolean           @default(false)
  priority                  Int               @default(1)
  notes                     String?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  material                  Material          @relation(fields: [materialId], references: [id], onDelete: Cascade)
  product                   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  productionWastes          ProductionWaste[]

  @@map("product_components")
}

model ProductOperation {
  id            String  @id @default(uuid())
  productId     String
  name          String
  costPerMinute Decimal @db.Decimal(10, 4)
  setupTime     Int     @default(0)
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id                        String                   @id @default(uuid())
  organizationId            String
  customerId                String
  orderNumber               String
  status                    OrderStatus              @default(DRAFT)
  subtotal                  Decimal                  @db.Decimal(10, 2)
  discount                  Decimal                  @default(0) @db.Decimal(10, 2)
  tax                       Decimal                  @default(0) @db.Decimal(10, 2)
  total                     Decimal                  @db.Decimal(10, 2)
  deliveryDate              DateTime?
  createdAt                 DateTime                 @default(now())
  validUntil                DateTime?
  updatedAt                 DateTime                 @updatedAt
  notes                     String?
  approvedAt                DateTime?
  cancellationPaymentAction String?
  cancellationReason        String?
  cancellationRefundAmount  Decimal?                 @db.Decimal(10, 2)
  cancelledAt               DateTime?
  cancelledById             String?
  deliveredAt               DateTime?
  finishedAt                DateTime?
  inProductionAt            DateTime?
  processStatusId           String?
  discountStatus            DiscountStatus           @default(NONE)
  authorizationRequestId    String?
  sellerId                  String?
  artDesignerId             String?
  artAssignedAt             DateTime?
  productionUserId          String?
  productionAssignedAt      DateTime?
  packagingUserId           String?
  packagingAssignedAt       DateTime?
  accountsReceivable        AccountReceivable[]
  commissionEntries         CommissionEntry[]
  deliveries                Delivery[]
  inventoryMovements        InventoryMovement[]
  items                     OrderItem[]
  statusHistory             OrderStatusHistory[]
  artDesigner               User?                    @relation("OrderArtDesigner", fields: [artDesignerId], references: [id])
  authorizationRequest      AuthorizationRequest?    @relation(fields: [authorizationRequestId], references: [id])
  cancelledBy               User?                    @relation("OrderCancelledBy", fields: [cancelledById], references: [id])
  customer                  Profile                  @relation(fields: [customerId], references: [id])
  organization              Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  packer                    User?                    @relation("OrderPacker", fields: [packagingUserId], references: [id])
  processStatus             ProcessStatus?           @relation(fields: [processStatusId], references: [id])
  producer                  User?                    @relation("OrderProducer", fields: [productionUserId], references: [id])
  seller                    User?                    @relation("OrderSeller", fields: [sellerId], references: [id])
  pendingChanges            PendingChanges[]
  productionQueue           ProductionQueue[]
  productionWastes          ProductionWaste[]
  balanceMovements          ProfileBalanceMovement[]
  stockReservations         StockReservation[]
  transactions              Transaction[]

  @@unique([organizationId, orderNumber])
  @@map("orders")
}

model OrderSequence {
  organizationId String       @id
  lastValue      Int          @default(0)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("order_sequences")
}

model OrderStatusHistory {
  id                  String         @id @default(uuid())
  orderId             String
  fromStatus          OrderStatus?
  toStatus            OrderStatus
  fromProcessStatusId String?
  toProcessStatusId   String?
  notes               String?
  userId              String?
  createdAt           DateTime       @default(now())
  fromProcessStatus   ProcessStatus? @relation("FromPS", fields: [fromProcessStatusId], references: [id])
  order               Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  toProcessStatus     ProcessStatus? @relation("ToPS", fields: [toProcessStatusId], references: [id])
  user                User?          @relation(fields: [userId], references: [id])

  @@map("order_status_history")
}

model OrderItem {
  id                     String                   @id @default(uuid())
  orderId                String
  productId              String
  itemType               ItemType                 @default(PRODUCT)
  width                  Decimal?                 @db.Decimal(10, 3)
  height                 Decimal?                 @db.Decimal(10, 3)
  quantity               Int
  totalArea              Decimal?                 @db.Decimal(10, 6)
  attributes             Json?
  area                   Float?
  paperSize              String?
  paperType              String?
  printColors            String?
  finishing              String?
  customSizeName         String?
  isCustomSize           Boolean                  @default(false)
  machineTime            Float?
  setupTime              Float?
  complexity             String?
  costPrice              Decimal                  @db.Decimal(10, 2)
  calculatedPrice        Decimal                  @db.Decimal(10, 2)
  unitPrice              Decimal                  @db.Decimal(10, 2)
  totalPrice             Decimal                  @db.Decimal(10, 2)
  notes                  String?
  processStatusId        String?
  status                 OrderStatus              @default(DRAFT)
  pricingRuleId          String?
  unitCostAtSale         Decimal?                 @db.Decimal(10, 4)
  unitPriceAtSale        Decimal?                 @db.Decimal(10, 2)
  profitAtSale           Decimal?                 @db.Decimal(10, 4)
  compositionSnapshot    Json?
