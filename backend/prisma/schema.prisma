generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                     String                  @id @default(uuid())
  name                   String
  cnpj                   String?                 @unique
  slug                   String                  @unique
  plan                   String                  @default("basic")
  active                 Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  accounts               Account[]
  auditLogs              AuditLog[]
  automationRules        AutomationRule[]
  budgets                Budget[]
  categories             Category[]
  configurationTemplates ConfigurationTemplate[]
  fichasTecnicas         FichaTecnicaInsumo[]
  finishes               Finish[]
  insumos                Insumo[]
  inventoryAlerts        InventoryAlert[]
  inventoryMovements     InventoryMovement[]
  machines               Machine[]
  materials              Material[]
  notifications          Notifications[]
  orders                 Order[]
  settings               OrganizationSettings?
  PaymentMethod          PaymentMethod[]
  pendingChanges         PendingChanges[]
  pricingRules           PricingRule[]
  processStatuses        ProcessStatus[]
  productionMaterials    ProductionMaterial[]
  productionQueue        ProductionQueue[]
  products               Product[]
  profiles               Profile[]
  standardSizes          StandardSize[]
  transactions           Transaction[]
  users                  User[]

  @@map("organizations")
}

model OrganizationSettings {
  id                   String       @id @default(uuid())
  organizationId       String       @unique
  enableWMS            Boolean      @default(false)
  enableProduction     Boolean      @default(false)
  enableFinance        Boolean      @default(true)
  enableAutomation     Boolean      @default(true)
  defaultMarkup        Float        @default(2.0)
  taxRate              Float        @default(0.0)
  validadeOrcamento    Int          @default(7)
  enableFinanceReports Boolean      @default(true)
  allowDuplicatePhones Boolean      @default(true)
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

model User {
  id                 String               @id @default(uuid())
  organizationId     String
  email              String
  password           String
  name               String
  role               UserRole             @default(USER)
  active             Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  auditLogs          AuditLog[]
  inventoryMovements InventoryMovement[]
  notifications      Notifications[]
  cancelledOrders    Order[]              @relation("OrderCancelledBy")
  requestedChanges   PendingChanges[]     @relation("RequestedBy")
  reviewedChanges    PendingChanges[]     @relation("ReviewedBy")
  profile            Profile?
  organization       Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  statusHistory      OrderStatusHistory[]

  @@unique([organizationId, email])
  @@map("users")
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  userId         String?
  action         String
  tableName      String
  recordId       String
  oldValues      Json?
  newValues      Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Profile {
  id                 String             @id @default(uuid())
  organizationId     String
  type               ProfileType
  name               String
  document           String?
  email              String?
  phone              String?
  address            String?
  city               String?
  state              String?
  zipCode            String?
  isCustomer         Boolean            @default(false)
  isSupplier         Boolean            @default(false)
  isEmployee         Boolean            @default(false)
  creditLimit        Decimal?           @db.Decimal(10, 2)
  paymentTerms       Int?
  active             Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  addressNumber      String?
  balance            Decimal            @default(0) @db.Decimal(15, 2)
  userId             String?            @unique
  budgets            Budget[]
  insumoFornecedores InsumoFornecedor[]
  orders             Order[]
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user               User?              @relation(fields: [userId], references: [id])

  @@unique([organizationId, document])
  @@map("profiles")
}

model Material {
  id               String             @id @default(uuid())
  organizationId   String
  name             String
  description      String?
  format           MaterialFormat
  costPerUnit      Decimal            @db.Decimal(10, 4)
  unit             String
  standardWidth    Float?
  standardLength   Float?
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  inventoryAlerts  InventoryAlert[]
  inventoryItems   InventoryItem[]
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  components       ProductComponent[]
  productionWastes ProductionWaste[]

  @@map("materials")
}

model InventoryItem {
  id         String              @id @default(uuid())
  materialId String
  width      Float
  length     Float?
  height     Float?
  thickness  Float?
  quantity   Int                 @default(1)
  location   String?
  isOffcut   Boolean             @default(false)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  material   Material            @relation(fields: [materialId], references: [id], onDelete: Cascade)
  movements  InventoryMovement[]

  @@map("inventory_items")
}

model Product {
  id               String                 @id @default(uuid())
  organizationId   String
  name             String
  description      String?
  productType      ItemType               @default(PRODUCT)
  pricingMode      PricingMode            @default(SIMPLE_AREA)
  salePrice        Decimal?               @db.Decimal(10, 2)
  minPrice         Decimal?               @db.Decimal(10, 2)
  costPrice        Decimal?               @db.Decimal(10, 2)
  markup           Float                  @default(2.0)
  active           Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  pricingRuleId    String?
  stockMinQuantity Float?
  stockQuantity    Float?
  stockUnit        String?
  trackStock       Boolean                @default(false)
  formulaData      Json?
  localFormulaId   String?
  customFormula    String?
  budgetItems      BudgetItem[]
  fichasTecnicas   FichaTecnicaInsumo[]
  orderItems       OrderItem[]
  components       ProductComponent[]
  configurations   ProductConfiguration[]
  operations       ProductOperation[]
  standardSizes    ProductStandardSize[]
  productionWastes ProductionWaste[]
  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pricingRule      PricingRule?           @relation(fields: [pricingRuleId], references: [id])

  @@map("products")
}

model ProductConfiguration {
  id                String                   @id @default(uuid())
  productId         String
  name              String
  description       String?
  helpText          String?
  type              ConfigurationType
  required          Boolean                  @default(true)
  defaultValue      String?
  affectsComponents Boolean                  @default(false)
  affectsPricing    Boolean                  @default(false)
  minValue          Float?
  maxValue          Float?
  step              Float?
  displayOrder      Int                      @default(1)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  options           ConfigurationOption[]
  orderItemConfigs  OrderItemConfiguration[]
  product           Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_configurations")
}

model ConfigurationOption {
  id                   String                   @id @default(uuid())
  configurationId      String
  label                String
  value                String
  description          String?
  priceModifier        Decimal                  @default(0) @db.Decimal(10, 2)
  priceModifierType    String                   @default("FIXED")
  additionalComponents Json?
  removedComponents    Json?
  componentModifiers   Json?
  isAvailable          Boolean                  @default(true)
  displayOrder         Int                      @default(1)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  configuration        ProductConfiguration     @relation(fields: [configurationId], references: [id], onDelete: Cascade)
  fichasTecnicas       FichaTecnicaInsumo[]
  orderItemConfigs     OrderItemConfiguration[]

  @@map("configuration_options")
}

model ConfigurationTemplate {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  description    String?
  category       String       @default("custom")
  configurations Json
  metadata       Json
  usageCount     Int          @default(0)
  createdBy      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("configuration_templates")
}

model OrderItemConfiguration {
  id               String               @id @default(uuid())
  orderItemId      String
  configurationId  String
  selectedValue    String
  selectedOptionId String?
  createdAt        DateTime             @default(now())
  configuration    ProductConfiguration @relation(fields: [configurationId], references: [id])
  orderItem        OrderItem            @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  selectedOption   ConfigurationOption? @relation(fields: [selectedOptionId], references: [id])

  @@map("order_item_configurations")
}

model ProductionWaste {
  id              String           @id @default(uuid())
  orderId         String
  productId       String
  materialId      String
  componentId     String
  plannedQuantity Float
  actualQuantity  Float
  wasteQuantity   Float
  wasteReason     String
  reportedBy      String
  reportedAt      DateTime         @default(now())
  component       ProductComponent @relation(fields: [componentId], references: [id])
  material        Material         @relation(fields: [materialId], references: [id])
  order           Order            @relation(fields: [orderId], references: [id])
  product         Product          @relation(fields: [productId], references: [id])

  @@map("production_wastes")
}

model ProductStandardSize {
  id        String  @id @default(uuid())
  productId String
  name      String
  width     Float
  height    Float
  isDefault Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_standard_sizes")
}

model ProductComponent {
  id                        String            @id @default(uuid())
  productId                 String
  materialId                String
  consumptionMethod         String
  wastePercentage           Float             @default(0.0)
  calculatedWastePercentage Float             @default(0.0)
  manualWastePercentage     Float?
  wasteUnits                Float             @default(0.0)
  manualWasteUnits          Float?
  lastWasteUpdate           DateTime          @default(now())
  wasteCalculationPeriod    Int               @default(90)
  isOptional                Boolean           @default(false)
  priority                  Int               @default(1)
  notes                     String?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  material                  Material          @relation(fields: [materialId], references: [id], onDelete: Cascade)
  product                   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  productionWastes          ProductionWaste[]

  @@map("product_components")
}

model ProductOperation {
  id            String  @id @default(uuid())
  productId     String
  name          String
  costPerMinute Decimal @db.Decimal(10, 4)
  setupTime     Int     @default(0)
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_operations")
}

model Order {
  id                        String               @id @default(uuid())
  organizationId            String
  customerId                String
  orderNumber               String
  status                    OrderStatus          @default(DRAFT)
  subtotal                  Decimal              @db.Decimal(10, 2)
  discount                  Decimal              @default(0) @db.Decimal(10, 2)
  tax                       Decimal              @default(0) @db.Decimal(10, 2)
  total                     Decimal              @db.Decimal(10, 2)
  deliveryDate              DateTime?
  createdAt                 DateTime             @default(now())
  validUntil                DateTime?
  updatedAt                 DateTime             @updatedAt
  notes                     String?
  approvedAt                DateTime?
  cancellationPaymentAction String?
  cancellationReason        String?
  cancellationRefundAmount  Decimal?             @db.Decimal(10, 2)
  cancelledAt               DateTime?
  cancelledById             String?
  deliveredAt               DateTime?
  finishedAt                DateTime?
  inProductionAt            DateTime?
  processStatusId           String?
  inventoryMovements        InventoryMovement[]
  items                     OrderItem[]
  cancelledBy               User?                @relation("OrderCancelledBy", fields: [cancelledById], references: [id])
  customer                  Profile              @relation(fields: [customerId], references: [id])
  organization              Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  processStatus             ProcessStatus?       @relation(fields: [processStatusId], references: [id])
  pendingChanges            PendingChanges[]
  productionQueue           ProductionQueue[]
  productionWastes          ProductionWaste[]
  transactions              Transaction[]
  statusHistory             OrderStatusHistory[]

  @@unique([organizationId, orderNumber])
  @@map("orders")
}

model OrderStatusHistory {
  id                  String       @id @default(uuid())
  orderId             String
  fromStatus          OrderStatus?
  toStatus            OrderStatus
  fromProcessStatusId String?
  toProcessStatusId   String?
  notes               String?
  userId              String?
  createdAt           DateTime     @default(now())

  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user              User?          @relation(fields: [userId], references: [id])
  fromProcessStatus ProcessStatus? @relation("FromPS", fields: [fromProcessStatusId], references: [id])
  toProcessStatus   ProcessStatus? @relation("ToPS", fields: [toProcessStatusId], references: [id])

  @@map("order_status_history")
}

model OrderItem {
  id              String                   @id @default(uuid())
  orderId         String
  productId       String
  itemType        ItemType                 @default(PRODUCT)
  width           Decimal?                 @db.Decimal(10, 3)
  height          Decimal?                 @db.Decimal(10, 3)
  quantity        Int
  totalArea       Decimal?                 @db.Decimal(10, 6)
  attributes      Json?
  area            Float?
  paperSize       String?
  paperType       String?
  printColors     String?
  finishing       String?
  customSizeName  String?
  isCustomSize    Boolean                  @default(false)
  machineTime     Float?
  setupTime       Float?
  complexity      String?
  costPrice       Decimal                  @db.Decimal(10, 2)
  calculatedPrice Decimal                  @db.Decimal(10, 2)
  unitPrice       Decimal                  @db.Decimal(10, 2)
  totalPrice      Decimal                  @db.Decimal(10, 2)
  notes           String?
  processStatusId String?
  status          OrderStatus              @default(DRAFT)
  pricingRuleId   String?
  configurations  OrderItemConfiguration[]
  order           Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  processStatus   ProcessStatus?           @relation(fields: [processStatusId], references: [id])
  product         Product                  @relation(fields: [productId], references: [id])
  pricingRule     PricingRule?             @relation(fields: [pricingRuleId], references: [id])

  @@map("order_items")
}

model Budget {
  id             String       @id @default(uuid())
  organizationId String
  customerId     String
  budgetNumber   String
  status         BudgetStatus @default(DRAFT)
  subtotal       Decimal      @db.Decimal(10, 2)
  discount       Decimal      @default(0) @db.Decimal(10, 2)
  tax            Decimal      @default(0) @db.Decimal(10, 2)
  total          Decimal      @db.Decimal(10, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  validUntil     DateTime?
  notes          String?
  items          BudgetItem[]
  customer       Profile      @relation(fields: [customerId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, budgetNumber])
  @@map("budgets")
}

model BudgetItem {
  id              String         @id @default(uuid())
  budgetId        String
  productId       String
  itemType        ItemType       @default(PRODUCT)
  width           Decimal?       @db.Decimal(10, 3)
  height          Decimal?       @db.Decimal(10, 3)
  quantity        Int
  totalArea       Decimal?       @db.Decimal(10, 6)
  attributes      Json?
  paperSize       String?
  paperType       String?
  printColors     String?
  finishing       String?
  customSizeName  String?
  isCustomSize    Boolean        @default(false)
  machineTime     Float?
  setupTime       Float?
  complexity      String?
  pricingRuleId   String?
  pricingRule     PricingRule?   @relation(fields: [pricingRuleId], references: [id])
  costPrice       Decimal        @db.Decimal(10, 2)
  calculatedPrice Decimal        @db.Decimal(10, 2)
  unitPrice       Decimal        @db.Decimal(10, 2)
  totalPrice      Decimal        @db.Decimal(10, 2)
  notes           String?
  processStatusId String?
  status          BudgetStatus   @default(DRAFT)
  budget          Budget         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  processStatus   ProcessStatus? @relation(fields: [processStatusId], references: [id])
  product         Product        @relation(fields: [productId], references: [id])

  @@map("budget_items")
}

model InventoryMovement {
  id              String        @id @default(uuid())
  organizationId  String
  inventoryItemId String
  type            MovementType
  quantity        Int
  reason          String?
  orderId         String?
  userId          String
  createdAt       DateTime      @default(now())
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  order           Order?        @relation(fields: [orderId], references: [id])
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id])

  @@map("inventory_movements")
}

model InventoryAlert {
  id             String       @id @default(uuid())
  organizationId String
  materialId     String
  type           AlertType
  threshold      Float
  currentLevel   Float
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  material       Material     @relation(fields: [materialId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("inventory_alerts")
}

model ProductionQueue {
  id             String                @id @default(uuid())
  organizationId String
  orderId        String
  priority       Int                   @default(1)
  status         ProductionStatus      @default(PENDING)
  scheduledStart DateTime?
  actualStart    DateTime?
  estimatedEnd   DateTime?
  actualEnd      DateTime?
  assignedTo     String?
  machineId      String?
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  operations     ProductionOperation[]
  order          Order                 @relation(fields: [orderId], references: [id])
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("production_queue")
}

model ProductionOperation {
  id                String          @id @default(uuid())
  productionQueueId String
  name              String
  description       String?
  sequence          Int
  estimatedMinutes  Int
  actualMinutes     Int?
  status            OperationStatus @default(PENDING)
  startedAt         DateTime?
  completedAt       DateTime?
  productionQueue   ProductionQueue @relation(fields: [productionQueueId], references: [id], onDelete: Cascade)

  @@map("production_operations")
}

model Machine {
  id              String        @id @default(uuid())
  organizationId  String
  name            String
  type            MachineType
  model           String?
  serialNumber    String?
  status          MachineStatus @default(AVAILABLE)
  maxWidth        Float?
  maxHeight       Float?
  speedPerMinute  Float?
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("machines")
}

model Account {
  id             String        @id @default(uuid())
  organizationId String
  name           String
  type           AccountType
  balance        Decimal       @default(0) @db.Decimal(15, 2)
  bank           String?
  agency         String?
  accountNumber  String?
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  paymentMethods PaymentMethod[]

  @@map("accounts")
}

model Transaction {
  id              String            @id @default(uuid())
  organizationId  String
  accountId       String
  type            TransactionType
  amount          Decimal           @db.Decimal(15, 2)
  description     String
  categoryId      String?
  orderId         String?
  dueDate         DateTime?
  paidAt          DateTime?
  status          TransactionStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  auditNotes      String?
  paymentMethodId String?
  account         Account           @relation(fields: [accountId], references: [id])
  category        Category?         @relation(fields: [categoryId], references: [id])
  order           Order?            @relation(fields: [orderId], references: [id])
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod?    @relation(fields: [paymentMethodId], references: [id])

  @@map("transactions")
}

model Category {
  id             String        @id @default(uuid())
  organizationId String
  name           String
  type           CategoryType
  color          String?
  parentId       String?
  active         Boolean       @default(true)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         Category?     @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children       Category[]    @relation("CategoryHierarchy")
  transactions   Transaction[]

  @@map("categories")
}

model PaymentMethod {
  id               String            @id @default(uuid())
  organizationId   String
  name             String
  type             PaymentMethodType
  feePercentage    Decimal           @default(0) @db.Decimal(5, 2)
  installmentRules Json?
  accountId        String?
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account          Account?          @relation(fields: [accountId], references: [id])
  transactions     Transaction[]

  @@map("payment_methods")
}

model PendingChanges {
  id              String                @id @default(uuid())
  orderId         String
  organizationId  String
  requestedBy     String
  requestedAt     DateTime              @default(now())
  changes         Json
  originalData    Json
  status          PendingChangeStatus   @default(PENDING)
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewComments  String?
  priority        PendingChangePriority @default(MEDIUM)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  order           Order                 @relation(fields: [orderId], references: [id])
  organization    Organization          @relation(fields: [organizationId], references: [id])
  requestedByUser User                  @relation("RequestedBy", fields: [requestedBy], references: [id])
  reviewedByUser  User?                 @relation("ReviewedBy", fields: [reviewedBy], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([orderId])
  @@index([requestedBy])
  @@index([createdAt])
  @@map("pending_changes")
}

model Notifications {
  id             String           @id @default(uuid())
  organizationId String
  userId         String?
  type           NotificationType
  title          String           @db.VarChar(255)
  message        String
  data           Json?
  read           Boolean          @default(false)
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id])
  user           User?            @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

model StandardSize {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  width          Decimal      @db.Decimal(10, 3)
  height         Decimal      @db.Decimal(10, 3)
  type           ItemType
  isDefault      Boolean      @default(false)
  description    String?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name, type])
  @@map("standard_sizes")
}

model ProductionMaterial {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  type           ItemType
  costPrice      Decimal      @db.Decimal(10, 4)
  salesPrice     Decimal      @db.Decimal(10, 4)
  unit           String       @default("m²")
  properties     Json?
  inStock        Boolean      @default(true)
  supplier       String?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name, type])
  @@map("production_materials")
}

model Finish {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  description    String?
  allowedTypes   ItemType[]
  priceType      String       @default("FIXED")
  priceValue     Decimal      @default(0) @db.Decimal(10, 2)
  processingTime Int?
  requiresSetup  Boolean      @default(false)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@map("finishes")
}

model AutomationRule {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  description    String?
  trigger        String
  action         String
  conditions     Json
  enabled        Boolean      @default(true)
  runCount       Int          @default(0)
  lastRun        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@map("automation_rules")
}

model ProcessStatus {
  id             String               @id @default(uuid())
  organizationId String
  name           String
  color          String?
  icon           String?
  parentId       String?
  mappedBehavior OrderStatus
  allowEdition   Boolean              @default(true)
  displayOrder   Int                  @default(1)
  hideFromFlow   Boolean              @default(false)
  active         Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  scope          StatusScope          @default(ORDER)
  budgetItems    BudgetItem[]
  orderItems     OrderItem[]
  orders         Order[]
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         ProcessStatus?       @relation("StatusHierarchy", fields: [parentId], references: [id])
  children       ProcessStatus[]      @relation("StatusHierarchy")
  fromHistory    OrderStatusHistory[] @relation("FromPS")
  toHistory      OrderStatusHistory[] @relation("ToPS")

  @@map("process_statuses")
}

model PricingRule {
  id             String        @id @default(uuid())
  organizationId String
  name           String
  active         Boolean       @default(true)
  type           ItemType
  parentId       String?
  formula        Json
  config         Json?
  version        Int           @default(1)
  isLatest       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  parent         PricingRule?  @relation("PricingRuleVersions", fields: [parentId], references: [id])
  versions       PricingRule[] @relation("PricingRuleVersions")
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products       Product[]
  orderItems     OrderItem[]
  BudgetItem     BudgetItem[]

  @@map("pricing_rules")
}

/// Matéria-prima usada no motor de cálculo de orçamentos dinâmicos
model Insumo {
  id             String               @id @default(uuid())
  organizationId String
  nome           String
  categoria      String
  unidadeBase    UnidadeBase
  custoUnitario  Decimal              @db.Decimal(10, 4)
  ativo          Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  fichasTecnicas FichaTecnicaInsumo[]
  fornecedores   InsumoFornecedor[]
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, categoria])
  @@index([organizationId, ativo])
  @@map("insumos")
}

/// Relação de quantidade de insumos associados a um Produto Base ou a uma Opção de Variação
model FichaTecnicaInsumo {
  id                    String               @id @default(uuid())
  organizationId        String
  insumoId              String
  productId             String?
  configurationOptionId String?
  quantidade            Float
  custoCalculado        Decimal              @db.Decimal(10, 4)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  option                ConfigurationOption? @relation(fields: [configurationOptionId], references: [id], onDelete: Cascade)
  insumo                Insumo               @relation(fields: [insumoId], references: [id])
  organization          Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product               Product?             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([configurationOptionId])
  @@map("ficha_tecnica_insumos")
}

model InsumoFornecedor {
  id           String   @id @default(uuid())
  insumoId     String
  fornecedorId String
  precoCusto   Decimal? @db.Decimal(10, 4)
  referencia   String?
  ativo        Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  fornecedor   Profile  @relation(fields: [fornecedorId], references: [id])
  insumo       Insumo   @relation(fields: [insumoId], references: [id], onDelete: Cascade)

  @@unique([insumoId, fornecedorId])
  @@map("insumo_fornecedores")
}

