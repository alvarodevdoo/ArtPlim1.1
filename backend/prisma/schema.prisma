  quantityRemaining Decimal?          @db.Decimal(15, 4)
  createdAt         DateTime          @default(now())
  cancelledBy       User?             @relation("CancelledMovements", fields: [cancelledById], references: [id])
  machine           Machine?          @relation(fields: [machineId], references: [id])
  material          Material          @relation(fields: [materialId], references: [id])
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier          Profile?          @relation("SupplierMovements", fields: [supplierId], references: [id])
  user              User?             @relation("UserMovements", fields: [userId], references: [id])

  @@index([organizationId])
  @@index([materialId])
  @@index([supplierId])
  @@map("stock_movements")
}

model Role {
  id                String            @id @default(uuid())
  organizationId    String
  name              String
  description       String?
  isSystem          Boolean           @default(false)
  active            Boolean           @default(true)
  createdAt         DateTime          @default(now())
  commissionEntries CommissionEntry[]
  commissionRules   CommissionRule[]
  permissions       RolePermission[]
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users             User[]

  @@unique([organizationId, name])
  @@map("roles")
}

model RolePermission {
  id            String @id @default(uuid())
  roleId        String
  permissionKey String
  role          Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionKey])
  @@map("role_permissions")
}

model CommissionRule {
  id             String       @id @default(uuid())
  organizationId String
  roleId         String
  rate           Decimal      @db.Decimal(10, 2)
  description    String?
  active         Boolean      @default(true)
  categoryId     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  category       Category?    @relation(fields: [categoryId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           Role         @relation(fields: [roleId], references: [id])

  @@map("commission_rules")
}

model CommissionEntry {
  id             String       @id @default(uuid())
  organizationId String
  orderId        String
  userId         String?
  roleId         String?
  amount         Decimal      @db.Decimal(10, 2)
  rateApplied    Decimal      @db.Decimal(10, 2)
  description    String
  status         String       @default("PENDING")
  categoryId     String?
  createdAt      DateTime     @default(now())
  category       Category?    @relation("CommissionEntryCategory", fields: [categoryId], references: [id])
  order          Order        @relation(fields: [orderId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           Role?        @relation(fields: [roleId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])

  @@map("commission_entries")
}

