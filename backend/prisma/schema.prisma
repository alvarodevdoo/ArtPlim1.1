generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id          String  @id @default(uuid())
  name        String // Nome Fantasia
  razaoSocial String? // Razão Social (Legal Name)
  cnpj        String? @unique
  slug        String  @unique
  plan        String  @default("basic")
  active      Boolean @default(true)

  // Contato e Endereço
  email         String?
  phone         String?
  zipCode       String? // CEP
  address       String? // Logradouro
  addressNumber String? // Número
  complement    String? // Complemento
  neighborhood  String? // Bairro
  city          String? // Cidade
  state         String? // UF (Ex: SP)

  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  accounts               Account[]
  accountsPayable        AccountPayable[]
  accountsReceivable     AccountReceivable[]
  auditLogs              AuditLog[]
  automationRules        AutomationRule[]
  budgets                Budget[]
  categories             Category[]
  chartOfAccounts        ChartOfAccount[]
  configurationTemplates ConfigurationTemplate[]
  fichasTecnicas         FichaTecnicaInsumo[]
  finishes               Finish[]
  inventoryAlerts        InventoryAlert[]
  inventoryMovements     InventoryMovement[]
  machines               Machine[]
  materialReceipts       MaterialReceipt[]
  materials              Material[]
  notifications          Notifications[]
  orders                 Order[]
  deliveries             Delivery[]
  settings               OrganizationSettings?
  PaymentMethod          PaymentMethod[]
  pendingChanges         PendingChanges[]
  pricingRules           PricingRule[]
  processStatuses        ProcessStatus[]
  productionMaterials    ProductionMaterial[]
  productionQueue        ProductionQueue[]
  products               Product[]
  profiles               Profile[]
  standardSizes          StandardSize[]
  transactions           Transaction[]
  users                  User[]
  roles                  Role[]
  stockMovements         StockMovement[]
  spedAccountMappings    SpedAccountMapping[]
  materialTypes          MaterialType[]
  productionOrders       ProductionOrder[]

  @@map("organizations")
}

model OrganizationSettings {
  id                         String  @id @default(uuid())
  organizationId             String  @unique
  enableWMS                  Boolean @default(false)
  enableProduction           Boolean @default(false)
  enableFinance              Boolean @default(true)
  enableAutomation           Boolean @default(true)
  defaultMarkup              Float   @default(2.0)
  taxRate                    Float   @default(0.0)
  validadeOrcamento          Int     @default(7)
  enableFinanceReports       Boolean @default(true)
  allowDuplicatePhones       Boolean @default(true)
  requireDocumentKeyForEntry Boolean @default(false)
  enableCategoryAppropriation Boolean @default(true)
  defaultSalesUnit           String  @default("MM")

  // Configurações de Apropriação Financeira (Plano de Contas)
  defaultReceivableCategoryId String?
  defaultRevenueCategoryId    String?
  freightExpenseAccountId     String?
  taxExpenseAccountId         String?

  // Método de Valoração de Estoque (AVERAGE_COST ou PEPS)
  inventoryValuationMethod String @default("AVERAGE")

  // Certificado Digital NF-e (A1)
  nfeCertificate         String? // Conteúdo .pfx em Base64
  nfeCertificatePassword String? // Senha criptografada
  nfeCertificateSubject  String?
  nfeCertificateFileName String?
  nfeCertificateExpiry   DateTime? // Data de expiração capturada no upload

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

model User {
  id                 String               @id @default(uuid())
  organizationId     String
  email              String
  password           String
  name               String
  role               UserRole             @default(USER) // Mantido para retrocompatibilidade
  roleId             String? // Novo: Relacionamento com Role (Departamento) customizado
  customRole         Role?                @relation(fields: [roleId], references: [id])
  active             Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  auditLogs          AuditLog[]
  inventoryMovements InventoryMovement[]
  notifications      Notifications[]
  statusHistory      OrderStatusHistory[]
  cancelledOrders    Order[]              @relation("OrderCancelledBy")
  requestedChanges   PendingChanges[]     @relation("RequestedBy")
  reviewedChanges    PendingChanges[]     @relation("ReviewedBy")
  profile            Profile?
  transactions       Transaction[]
  stockMovements     StockMovement[]      @relation("UserMovements")
  cancelledMovements StockMovement[]      @relation("CancelledMovements")
  organization       Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@map("users")
}

enum SpedAccountType {
  INVENTORY
  EXPENSE
}

model MaterialType {
  id             String               @id @default(uuid())
  name           String // Nome amigável (ex: Tintas, Chapas, etc)
  spedCode       String // Código SPED base (00, 01, 07...)
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id])
  mappings       SpedAccountMapping[]
  materials      Material[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([organizationId])
}

model SpedAccountMapping {
  id             String          @id @default(uuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  materialTypeId String? // Agora vinculado ao tipo dinâmico
  materialType   MaterialType?   @relation(fields: [materialTypeId], references: [id], onDelete: Cascade)
  spedType       String // Mantido para compatibilidade legado (valor do spedCode do tipo)
  accountId      String
  account        ChartOfAccount  @relation(fields: [accountId], references: [id])
  mappingType    SpedAccountType @default(EXPENSE) // INVENTORY ou EXPENSE
  createdAt      DateTime        @default(now())

  @@index([organizationId, materialTypeId])
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  userId         String?
  action         String
  tableName      String
  recordId       String
  oldValues      Json?
  newValues      Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Profile {
  id                 String              @id @default(uuid())
  organizationId     String
  type               ProfileType
  name               String
  document           String?
  email              String?
  phone              String?
  address            String?
  city               String?
  state              String?
  zipCode            String?
  isCustomer         Boolean             @default(false)
  isSupplier         Boolean             @default(false)
  isEmployee         Boolean             @default(false)
  creditLimit        Decimal?            @db.Decimal(10, 2)
  paymentTerms       Int?
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  addressNumber      String?
  balance            Decimal             @default(0) @db.Decimal(15, 2)
  userId             String?             @unique
  AccountPayable     AccountPayable[]
  AccountReceivable  AccountReceivable[] @relation("CustomerReceivables")
  budgets            Budget[]
  insumoFornecedores InsumoFornecedor[]
  MaterialReceipt    MaterialReceipt[]
  materialSuppliers  MaterialSupplier[]
  orders             Order[]
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user               User?               @relation(fields: [userId], references: [id])
  transactions       Transaction[]
  stockMovements     StockMovement[]     @relation("SupplierMovements")

  @@unique([organizationId, name], name: "organizationId_name")
  @@unique([organizationId, document], name: "organizationId_document")
  @@map("profiles")
}

model Material {
  id                       String                @id @default(uuid())
  organizationId           String
  name                     String
  description              String?
  format                   MaterialFormat
  costPerUnit              Decimal               @db.Decimal(10, 4)
  unit                     String
  controlUnit              ControlUnit?
  conversionFactor         Float                 @default(1.0)
  width                    Float?
  height                   Float?
  purchaseWidth            Float?                // Largura de compra em metros
  purchaseHeight           Float?                // Altura de compra em metros
  purchaseUnit             String?               // Unidade de compra (Ex: UN, PAC, CX)
  multiplicador_padrao_entrada Int?              @default(1) // Fator de Embalagem Sugerido
  active                   Boolean               @default(true)
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  categoryId               String // Nova chave estrangeira
  category                 Category              @relation(fields: [categoryId], references: [id])
  defaultConsumptionFactor Decimal               @default(1.0) @db.Decimal(10, 4)
  defaultConsumptionRule   ConsumptionRule       @default(FIXED_UNIT)
  expenseAccountId         String?
  inventoryAccountId       String?
  minStockQuantity         Float?
  sellWithoutStock         Boolean               @default(true)
  trackStock               Boolean               @default(true)
  ncm                      String?
  ean                      String?
  spedType                 String? // Legado: código do tipo (00, 01...)
  materialTypeId           String? // Dinâmico: ID da classificação criada pelo usuário
  materialType             MaterialType?         @relation(fields: [materialTypeId], references: [id])
  fichasTecnicas           FichaTecnicaInsumo[]
  fornecedores             InsumoFornecedor[]
  inventoryAlerts          InventoryAlert[]
  inventoryItems           InventoryItem[]
  receiptItems             MaterialReceiptItem[]
  suppliers                MaterialSupplier[]
  stockMovements           StockMovement[]
  expenseAccount           ChartOfAccount?       @relation("MaterialExpenseAccount", fields: [expenseAccountId], references: [id])
  inventoryAccount         ChartOfAccount?       @relation("MaterialInventoryAccount", fields: [inventoryAccountId], references: [id])
  organization             Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  components               ProductComponent[]
  productionWastes         ProductionWaste[]
  averageCost              Decimal               @default(0) @db.Decimal(10, 4)
  purchasePrice            Decimal?              @db.Decimal(10, 2)
  currentStock             Decimal               @default(0) @db.Decimal(15, 4)
  // Motor de Composição: opções de variação vinculadas a este insumo
  optionSlots              ConfigurationOption[] @relation("OptionMaterial")

  @@unique([organizationId, name], name: "organizationId_name")
  @@index([organizationId])
  @@index([organizationId, categoryId])
  @@index([organizationId, active])
  @@map("materials")
}

model InventoryItem {
  id         String              @id @default(uuid())
  materialId String
  width      Float
  length     Float?
  height     Float?
  thickness  Float?
  quantity   Int                 @default(1)
  location   String?
  isOffcut   Boolean             @default(false)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  material   Material            @relation(fields: [materialId], references: [id], onDelete: Cascade)
  movements  InventoryMovement[]

  @@map("inventory_items")
}

model Product {
  id               String                 @id @default(uuid())
  organizationId   String
  name             String
  description      String?
  productType      ItemType               @default(PRODUCT)
  pricingMode      PricingMode            @default(SIMPLE_AREA)
  salePrice        Decimal?               @db.Decimal(10, 2)
  minPrice         Decimal?               @db.Decimal(10, 2)
  costPrice        Decimal?               @db.Decimal(10, 2)
  markup           Float                  @default(2.0)
  active           Boolean                @default(true)
  priceLocked      Boolean                @default(false)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  pricingRuleId    String?
  stockMinQuantity Float?
  stockQuantity    Float?
  stockUnit        String?
  trackStock       Boolean                @default(false)
  formulaData      Json?
  localFormulaId   String?
  customFormula    String?
  sellWithoutStock Boolean                @default(true)
  // Motor de Composição: markup alvo para sugestão de preço
  targetMarkup     Float?                 // Multiplicador sobre custo (ex: 2.5 = 250%)
  targetMargin     Float?                 // Margem alvo alternativa 0.0–1.0 (ex: 0.40 = 40%)
  budgetItems      BudgetItem[]
  fichasTecnicas   FichaTecnicaInsumo[]
  orderItems       OrderItem[]
  components       ProductComponent[]
  configurations   ProductConfiguration[]
  operations       ProductOperation[]
  standardSizes    ProductStandardSize[]
  productionWastes ProductionWaste[]
  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pricingRule      PricingRule?           @relation(fields: [pricingRuleId], references: [id])
  categoryId       String?
  category         Category?              @relation(fields: [categoryId], references: [id])
  revenueAccountId String?
  revenueAccount   ChartOfAccount?        @relation("ProductRevenueAccount", fields: [revenueAccountId], references: [id])

  @@unique([organizationId, name], name: "organizationId_name")
  @@map("products")
}

model ProductConfiguration {
  id                String                   @id @default(uuid())
  productId         String
  name              String
  description       String?
  helpText          String?
  type              ConfigurationType
  required          Boolean                  @default(true)
  defaultValue      String?
  affectsComponents Boolean                  @default(false)
  affectsPricing    Boolean                  @default(false)
  minValue          Float?
  maxValue          Float?
  step              Float?
  displayOrder      Int                      @default(1)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  options           ConfigurationOption[]
  orderItemConfigs  OrderItemConfiguration[]
  product           Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_configurations")
}

model ConfigurationOption {
  id                   String                   @id @default(uuid())
  configurationId      String
  label                String
  value                String
  description          String?
  priceModifier        Decimal                  @default(0) @db.Decimal(10, 2)
  priceModifierType    String                   @default("FIXED")
  priceOverride        Decimal?                 @db.Decimal(10, 2) // Sobrescreve o preço global se definido
  fixedValue           Decimal?                 @db.Decimal(10, 2) // Novo campo para Valor Fixo de Venda
  additionalComponents Json?
  removedComponents    Json?
  componentModifiers   Json?
  isAvailable          Boolean                  @default(true)
  displayOrder         Int                      @default(1)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  // Motor de Composição: vínculo direto com insumo do estoque ("slot de variável")
  materialId           String?                  // FK para Material — custo lido de averageCost
  slotQuantity         Decimal?                 @db.Decimal(10, 4) // Qtd padrão deste insumo
  configuration        ProductConfiguration     @relation(fields: [configurationId], references: [id], onDelete: Cascade)
  material             Material?                @relation("OptionMaterial", fields: [materialId], references: [id])
  fichasTecnicas       FichaTecnicaInsumo[]
  orderItemConfigs     OrderItemConfiguration[]
  incompatibilitiesA   OptionIncompatibility[]  @relation("IncompatA")
  incompatibilitiesB   OptionIncompatibility[]  @relation("IncompatB")

  @@map("configuration_options")
}

// Motor de Composição: pares de opções mutuamente exclusivas
model OptionIncompatibility {
  id        String              @id @default(uuid())
  optionAId String
  optionBId String
  reason    String?             // Explicação exibida ao usuário
  createdAt DateTime            @default(now())
  optionA   ConfigurationOption @relation("IncompatA", fields: [optionAId], references: [id], onDelete: Cascade)
  optionB   ConfigurationOption @relation("IncompatB", fields: [optionBId], references: [id], onDelete: Cascade)

  @@unique([optionAId, optionBId])
  @@map("option_incompatibilities")
}

model ConfigurationTemplate {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  description    String?
  category       String       @default("custom")
  configurations Json
  metadata       Json
  usageCount     Int          @default(0)
  createdBy      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("configuration_templates")
}

model OrderItemConfiguration {
  id               String               @id @default(uuid())
  orderItemId      String
  configurationId  String
  selectedValue    String
  selectedOptionId String?
  createdAt        DateTime             @default(now())
  configuration    ProductConfiguration @relation(fields: [configurationId], references: [id])
  orderItem        OrderItem            @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  selectedOption   ConfigurationOption? @relation(fields: [selectedOptionId], references: [id])

  @@map("order_item_configurations")
}

model ProductionWaste {
  id              String           @id @default(uuid())
  orderId         String
  productId       String
  materialId      String
  componentId     String
  plannedQuantity Float
  actualQuantity  Float
  wasteQuantity   Float
  wasteReason     String
  reportedBy      String
  reportedAt      DateTime         @default(now())
  component       ProductComponent @relation(fields: [componentId], references: [id])
  material        Material         @relation(fields: [materialId], references: [id])
  order           Order            @relation(fields: [orderId], references: [id])
  product         Product          @relation(fields: [productId], references: [id])

  @@map("production_wastes")
}

model ProductStandardSize {
  id        String  @id @default(uuid())
  productId String
  name      String
  width     Float
  height    Float
  isDefault Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_standard_sizes")
}

model ProductComponent {
  id                        String            @id @default(uuid())
  productId                 String
  materialId                String
  consumptionMethod         String
  wastePercentage           Float             @default(0.0)
  calculatedWastePercentage Float             @default(0.0)
  manualWastePercentage     Float?
  wasteUnits                Float             @default(0.0)
  manualWasteUnits          Float?
  lastWasteUpdate           DateTime          @default(now())
  wasteCalculationPeriod    Int               @default(90)
  isOptional                Boolean           @default(false)
  priority                  Int               @default(1)
  notes                     String?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  material                  Material          @relation(fields: [materialId], references: [id], onDelete: Cascade)
  product                   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  productionWastes          ProductionWaste[]

  @@map("product_components")
}

model ProductOperation {
  id            String  @id @default(uuid())
  productId     String
  name          String
  costPerMinute Decimal @db.Decimal(10, 4)
  setupTime     Int     @default(0)
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_operations")
}

model Order {
  id                        String               @id @default(uuid())
  organizationId            String
  customerId                String
  orderNumber               String
  status                    OrderStatus          @default(DRAFT)
  subtotal                  Decimal              @db.Decimal(10, 2)
  discount                  Decimal              @default(0) @db.Decimal(10, 2)
  tax                       Decimal              @default(0) @db.Decimal(10, 2)
  total                     Decimal              @db.Decimal(10, 2)
  deliveryDate              DateTime?
  createdAt                 DateTime             @default(now())
  validUntil                DateTime?
  updatedAt                 DateTime             @updatedAt
  notes                     String?
  approvedAt                DateTime?
  cancellationPaymentAction String?
  cancellationReason        String?
  cancellationRefundAmount  Decimal?             @db.Decimal(10, 2)
  cancelledAt               DateTime?
  cancelledById             String?
  deliveredAt               DateTime?
  finishedAt                DateTime?
  inProductionAt            DateTime?
  processStatusId           String?
  accountsReceivable        AccountReceivable[]
  inventoryMovements        InventoryMovement[]
  items                     OrderItem[]
  statusHistory             OrderStatusHistory[]
  cancelledBy               User?                @relation("OrderCancelledBy", fields: [cancelledById], references: [id])
  customer                  Profile              @relation(fields: [customerId], references: [id])
  organization              Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  processStatus             ProcessStatus?       @relation(fields: [processStatusId], references: [id])
  pendingChanges            PendingChanges[]
  productionQueue           ProductionQueue[]
  productionWastes          ProductionWaste[]
  transactions              Transaction[]
  deliveries                Delivery[]

  @@unique([organizationId, orderNumber])
  @@map("orders")
}

model OrderStatusHistory {
  id                  String         @id @default(uuid())
  orderId             String
  fromStatus          OrderStatus?
  toStatus            OrderStatus
  fromProcessStatusId String?
  toProcessStatusId   String?
  notes               String?
  userId              String?
  createdAt           DateTime       @default(now())
  fromProcessStatus   ProcessStatus? @relation("FromPS", fields: [fromProcessStatusId], references: [id])
  order               Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  toProcessStatus     ProcessStatus? @relation("ToPS", fields: [toProcessStatusId], references: [id])
  user                User?          @relation(fields: [userId], references: [id])

  @@map("order_status_history")
}

model OrderItem {
  id              String                   @id @default(uuid())
  orderId         String
  productId       String
  itemType        ItemType                 @default(PRODUCT)
  width           Decimal?                 @db.Decimal(10, 3)
  height          Decimal?                 @db.Decimal(10, 3)
  quantity        Int
  totalArea       Decimal?                 @db.Decimal(10, 6)
  attributes      Json?
  area            Float?
  paperSize       String?
  paperType       String?
  printColors     String?
  finishing       String?
  customSizeName  String?
  isCustomSize    Boolean                  @default(false)
  machineTime     Float?
  setupTime       Float?
  complexity      String?
  costPrice            Decimal                  @db.Decimal(10, 2)
  calculatedPrice      Decimal                  @db.Decimal(10, 2)
  unitPrice            Decimal                  @db.Decimal(10, 2)
  totalPrice           Decimal                  @db.Decimal(10, 2)
  notes                String?
  processStatusId      String?
  status               OrderStatus              @default(DRAFT)
  pricingRuleId        String?
  // Motor de Composição: campos de snapshot (imutáveis após APPROVED)
  unitCostAtSale       Decimal?                 @db.Decimal(10, 4) // Custo médio ponderado no momento da venda
  unitPriceAtSale      Decimal?                 @db.Decimal(10, 2) // Preço negociado confirmado
  profitAtSale         Decimal?                 @db.Decimal(10, 4) // Lucro líquido: unitPriceAtSale – unitCostAtSale
  compositionSnapshot  Json?                    // BOM completa congelada: [{materialId, quantity, costPerUnit, subtotal}]
  confirmedAt          DateTime?                // Timestamp da confirmação (APPROVED)
  configurations       OrderItemConfiguration[]
  order                Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pricingRule          PricingRule?             @relation(fields: [pricingRuleId], references: [id])
  processStatus        ProcessStatus?           @relation(fields: [processStatusId], references: [id])
  product              Product                  @relation(fields: [productId], references: [id])
  deliveryItems        DeliveryItem[]
  productionOrder      ProductionOrder?

  @@map("order_items")
}

model Delivery {
  id             String         @id @default(uuid())
  organizationId String
  orderId        String
  deliveryDate   DateTime?      @default(now())
  status         DeliveryStatus @default(PENDING)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  order        Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        DeliveryItem[]

  @@map("deliveries")
}

model DeliveryItem {
  id          String @id @default(uuid())
  deliveryId  String
  orderItemId String
  quantity    Int

  delivery  Delivery  @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("delivery_items")
}

model Budget {
  id             String       @id @default(uuid())
  organizationId String
  customerId     String
  budgetNumber   String
  status         BudgetStatus @default(DRAFT)
  subtotal       Decimal      @db.Decimal(10, 2)
  discount       Decimal      @default(0) @db.Decimal(10, 2)
  tax            Decimal      @default(0) @db.Decimal(10, 2)
  total          Decimal      @db.Decimal(10, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  validUntil     DateTime?
  notes          String?
  items          BudgetItem[]
  customer       Profile      @relation(fields: [customerId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, budgetNumber])
  @@map("budgets")
}

model BudgetItem {
  id              String         @id @default(uuid())
  budgetId        String
  productId       String
  itemType        ItemType       @default(PRODUCT)
  width           Decimal?       @db.Decimal(10, 3)
  height          Decimal?       @db.Decimal(10, 3)
  quantity        Int
  totalArea       Decimal?       @db.Decimal(10, 6)
  attributes      Json?
  paperSize       String?
  paperType       String?
  printColors     String?
  finishing       String?
  customSizeName  String?
  isCustomSize    Boolean        @default(false)
  machineTime     Float?
  setupTime       Float?
  complexity      String?
  costPrice       Decimal        @db.Decimal(10, 2)
  calculatedPrice Decimal        @db.Decimal(10, 2)
  unitPrice       Decimal        @db.Decimal(10, 2)
  totalPrice      Decimal        @db.Decimal(10, 2)
  notes           String?
  processStatusId String?
  status          BudgetStatus   @default(DRAFT)
  pricingRuleId   String?
  budget          Budget         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  pricingRule     PricingRule?   @relation(fields: [pricingRuleId], references: [id])
  processStatus   ProcessStatus? @relation(fields: [processStatusId], references: [id])
  product         Product        @relation(fields: [productId], references: [id])

  @@map("budget_items")
}

model InventoryMovement {
