model StockMovement {
  id              String            @id @default(uuid())
  organizationId   String
  materialId      String
  userId          String?           // Usuário que realizou o ajuste
  type            StockMovementType
  quantity        Decimal           @db.Decimal(15, 4)
  unitCost        Decimal           @db.Decimal(10, 4)
  totalCost       Decimal           @db.Decimal(10, 4)
  oldQuantity     Decimal?          @db.Decimal(15, 4) // Saldo antes do ajuste
  oldUnitCost     Decimal?          @db.Decimal(10, 4) // Custo antes do ajuste
  machineId       String?
  machineCounter  Int?
  notes           String?
  justification   String?           // Justificativa do ajuste
  movementNumber  String?           @unique // Número único da transação
  documentUrl     String?           // Link para documento anexo
  supplierId      String?
  documentKey     String?
  isCancelled     Boolean           @default(false)
  cancelledAt     DateTime?
  cancelledById   String?
  quantityRemaining Decimal?          @db.Decimal(15, 4) // Saldo restante deste lote (para PEPS)
  createdAt       DateTime          @default(now())
  
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  material        Material          @relation(fields: [materialId], references: [id])
  machine         Machine?          @relation(fields: [machineId], references: [id])
  supplier        Profile?          @relation("SupplierMovements", fields: [supplierId], references: [id])
  user            User?             @relation("UserMovements", fields: [userId], references: [id])
  cancelledBy     User?             @relation("CancelledMovements", fields: [cancelledById], references: [id])

  @@index([organizationId])
  @@index([materialId])
  @@index([supplierId])
  @@map("stock_movements")
}

enum StockMovementType {
  ENTRY
  INTERNAL_CONSUMPTION
  ADJUSTMENT
}

model Role {
