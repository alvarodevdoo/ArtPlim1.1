  categoryExpenseAccounts   Category[]     @relation("CategoryExpenseAccount")
  spedAccountMappings SpedAccountMapping[]
  paymentMethodsFee   PaymentMethod[]      @relation("PaymentMethodFee")

  @@unique([organizationId, code], name: "organizationId_code")
  @@map("chart_of_accounts")
}

