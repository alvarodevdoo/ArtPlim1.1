# ============================================================
# .env.prod.example
#
# Copie este arquivo para .env.prod e preencha com valores REAIS.
# O .env.prod NAO deve ser commitado (esta no .gitignore).
#
# Gerar segredos seguros:
#   openssl rand -base64 32      # para JWT_SECRET, senhas, etc
# ============================================================

# ---- Postgres ----------------------------------------------
POSTGRES_DB=artplim_erp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-por-uma-senha-forte

# ---- Redis -------------------------------------------------
REDIS_PASSWORD=troque-por-uma-senha-forte

# ---- Backend / JWT -----------------------------------------
# Gere com: openssl rand -base64 48
JWT_SECRET=troque-por-um-segredo-aleatorio-longo

# ---- Cloudflare Tunnel -------------------------------------
# Pegue no painel: Zero Trust > Networks > Tunnels > (seu tunel) > Install connector
CLOUDFLARE_TUNNEL_TOKEN=cole-aqui-o-token-do-tunel

# ---- Porta do frontend exposta para intranet ---------------
# Padrao 80. Mude se a 80 ja estiver em uso na maquina.
FRONTEND_HOST_PORT=80

# ---- CORS --------------------------------------------------
# Lista separada por virgula das origens ESTATICAS permitidas pelo backend.
# Mantenha aqui apenas o que NAO se resolve por subdominio dinamico:
# - http://localhost (acesso local na maquina do servidor)
# Dominios publicos como https://erp.artplim.com.br NAO devem entrar aqui;
# eles sao liberados automaticamente quando "erp" estiver cadastrado em
# Organization.subdomain (ver CORS_BASE_DOMAINS abaixo).
# IPs da intranet (192.168.x.x, 10.x.x.x, ...) sao tratados por
# CORS_ALLOW_INTRANET, nao precisam ser listados aqui.
CORS_ALLOWED_ORIGINS=http://localhost

# OBRIGATORIO. Dominio(s) base para CORS dinamico por subdominio (lista
# separada por virgula). Uma origem https://<sub>.<base> so e liberada quando
# <sub> esta cadastrado em Organization.subdomain. O apex (https://<base>)
# NAO e permitido. O backend RECUSA iniciar se esta variavel estiver vazia.
CORS_BASE_DOMAINS=artplim.com.br

# Liberar origens da intranet (IPs privados RFC1918 + loopback + *.local).
# Use 'true' quando houver acesso direto via LAN (ex.: http://192.168.1.50)
# sem precisar listar cada IP em CORS_ALLOWED_ORIGINS.
CORS_ALLOW_INTRANET=true

# ---- Sincronizacao de schema do banco (Prisma) ------------
# Controla o comportamento do `prisma db push` no start do backend:
#   prompt (padrao) - aplica push seguro; se exigir PERDA DE DADOS,
#                     pergunta antes (se TTY) ou PULA (deploy normal).
#   accept          - aplica push aceitando perda (--accept-data-loss).
#                     CUIDADO: pode apagar colunas/tabelas.
#   skip            - nao toca no schema do banco.
DB_PUSH_MODE=prompt
